/// Checked structural template contracts.
namespace compiler.semantic.template

use compiler.semantic.types.*

/// Template obligation recorded at definition time.
data TemplateObligation {
    TemplateField(TypeVar, RowFieldId, SemType),
    TemplateMethod(TypeVar, String),
    TemplateOperator(TypeVar, String),
}

/// Checked generic body summary.
type CheckedTemplate {
    scheme: TypeScheme,
    obligations: Array[TemplateObligation],
}

/// Check a generic body under abstract parameters.
def check_template(module: TypedModule): Result[Array[CheckedTemplate], SemanticDiagnostics] = __compiler_builtin("std.semantic_check_template")
