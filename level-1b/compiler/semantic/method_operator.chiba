/// Nominal method and operator index.
namespace compiler.semantic.method_operator

use compiler.semantic.types.*

/// Method index key. Receiver identity is nominal and namespace-qualified.
type MethodKey {
    receiver: NominalId,
    name: String,
}

/// Operator index key.
type OperatorKey {
    receiver: NominalId,
    operator_name: String,
}

/// Method/operator index for one project.
type MethodOperatorIndex {
    methods: Array[MethodKey],
    operators: Array[OperatorKey],
}

/// Build the nominal method/operator index.
def build_method_operator_index(module: TypedModule): Result[MethodOperatorIndex, SemanticDiagnostics] =
    Ok(MethodOperatorIndex(Vec[MethodKey].new().freeze(), Vec[OperatorKey].new().freeze()))
