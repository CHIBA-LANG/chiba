namespace level1b.std_surface.refs_atomic

#[world_local]
def local_counter: Ref[i64] = Ref.new(0)

def refs_atomic_smoke(r: Ref[i64], a: Atomic[i64], p: Ptr[u8], u: UnsafeRef[String]): i64 = {
    let current = Ref.get(r)
    let _ = r := current + 1
    let _ = Atomic.load(a, Acquire)
    let _ = Atomic.store(a, current, Release)
    let _ = Ptr.addr(p)
    let _ = UnsafeRef.get(u)
    0
}
